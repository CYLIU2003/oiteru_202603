# ========================================
# OITERU サーバー設定ファイル (.env)
# ========================================
# このファイルをコピーして .env として使用してください
# Docker Compose または起動スクリプトから参照する想定です

# --- サーバー識別情報 ---
SERVER_NAME=OITERU親機
SERVER_LOCATION=本館1階

# --- Flask / 管理画面 ---
# ランダムな32文字以上の値を設定
FLASK_SECRET_KEY=change-this-secret-key

# 初回起動時の管理者パスワード
# 既定値は存在しないため、必ず変更してください
OITERU_ADMIN_PASSWORD=change-this-admin-password

ADMIN_SESSION_MINUTES=30
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_BLOCK_WINDOW_SECONDS=900
SESSION_COOKIE_SECURE=false
# mysql 構成では既定で true 扱い。必要時のみ false に変更
OITERU_STRICT_SECURITY=true

# --- データベース設定 ---
# 標準構成は mysql を使用
DB_TYPE=mysql

# MySQLを使用する場合のみ設定
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=oiteru_user
MYSQL_PASSWORD=change-this-mysql-password
MYSQL_ROOT_PASSWORD=change-this-root-password
MYSQL_DATABASE=oiteru

# --- 自動登録モード ---
# 未登録カードがタッチされた際に自動でユーザー登録する
# true: 有効（運用開始時に便利）
# false: 無効（事前登録が必要）
AUTO_REGISTER_MODE=true

# 自動登録時の初期残数
# ユーザーが1日に取得できる生理用品の最大数
AUTO_REGISTER_STOCK=2
USAGE_LIMIT=2
LIMIT_PERIOD=day
