# ========================================
# OITELU サーバー設定ファイル (.env)
# ========================================
# このファイルをコピーして .env として使用してください
# Docker Compose または python server.py で読み込まれます

# --- サーバー識別情報 ---
SERVER_NAME=OITERU親機
SERVER_LOCATION=本館1階

# --- データベース設定 ---
# sqlite または mysql を指定
DB_TYPE=sqlite

# MySQLを使用する場合のみ設定
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=oiteru_user
MYSQL_PASSWORD=oiteru_password_2025
MYSQL_DATABASE=oiteru

# --- 自動登録モード ---
# 未登録カードがタッチされた際に自動でユーザー登録する
# true: 有効（運用開始時に便利）
# false: 無効（事前登録が必要）
AUTO_REGISTER_MODE=true

# 自動登録時の初期残数
# ユーザーが1日に取得できるお菓子の最大数
AUTO_REGISTER_STOCK=2
